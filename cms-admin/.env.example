# cms-admin (Vite) environment variables.
# Vite inlines every VITE_* var into the bundle at BUILD time — so these must be
# set in Vercel → Project → Settings → Environment Variables (a change requires a
# redeploy to take effect). Copy this file to .env for local dev.

# Supabase (the CMS data + auth backend) — required
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-key>

# Medusa backend — the Reviews page fetches the product list from the BROWSER,
# so use the PUBLIC API URL in production (not localhost). The backend's
# STORE_CORS must include https://cms.delfee.in for this to work.
VITE_MEDUSA_BACKEND_URL=https://api.delfee.in
VITE_MEDUSA_PUBLISHABLE_KEY=<medusa-publishable-key>
